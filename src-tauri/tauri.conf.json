{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zyringe",
  "version": "0.1.0",
  "identifier": "eu.zlogic.zyringe",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zyringe",
        "width": 980,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "theme": "Dark",
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "publisher": "TheHolyOneZ",
    "copyright": "Copyright © 2026 TheHolyOneZ — GPL-3.0-only",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
